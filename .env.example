# haynesnetwork environment contract — see docs/designs/002-auth-and-authentik.md (D-08).
# Local dev: copy to .env.local (gitignored). Cluster: External Secrets + 1Password
# (HaynesKube vault) — secrets never land in git (CLAUDE.md hard rule 7).

# Postgres 16 connection string, consumed by @hnet/db.
# In-cluster: CNPG at postgres16-rw.database.svc.cluster.local:5432.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/haynesnetwork

# Session-cookie signing/encryption. Required in prod (dev-only fallback constant otherwise).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-at-least-32-random-chars

# Canonical origin; the OIDC redirect URI is derived from it — must match the
# registered redirect URI for the environment (DESIGN-002 D-04/D-11).
BETTER_AUTH_URL=http://localhost:3000

# OPTIONAL extra origins added to Better Auth's trustedOrigins allowlist, comma-separated
# (full origins: scheme + host, no path). BETTER_AUTH_URL is always trusted implicitly; this
# is for the OTHER origins the same app is served at. Public cutover behind the Cloudflare
# Tunnel serves both apex + www, so a sign-in from www is rejected as an Origin mismatch
# unless www is listed here. Cluster (apex is BETTER_AUTH_URL): set to the www origin, e.g.
#   TRUSTED_ORIGINS=https://www.haynesnetwork.com
# Leave unset for local dev and LAN staging (their own BETTER_AUTH_URL is the trusted origin).
# Keep it minimal — apex/www/staging only; do not broaden.
TRUSTED_ORIGINS=

# Authentik OIDC provider credentials — sign-in is disabled when unset.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Optional override (e2e OIDC stub per ADR-010, or future IdP moves). Default:
# https://authentik.haynesnetwork.com/application/o/haynesnetwork/.well-known/openid-configuration
OIDC_DISCOVERY_URL=

# Comma-separated, case-insensitive Admin allowlist (R-02); promotion hook no-ops when unset.
BOOTSTRAP_ADMIN_EMAILS=manofoz@gmail.com,t.haynes43@gmail.com

# --- *arr / Seerr media stack (@hnet/arr) — DESIGN-005 D-18 env contract ------------
# URLs are non-secret config. When unset they default to the in-cluster service DNS
# (what the deployed app/CronJobs use):
#   http://sonarr.media.svc.cluster.local:8989   http://radarr.media.svc.cluster.local:7878
#   http://lidarr.media.svc.cluster.local:8686   http://seerr.media.svc.cluster.local:5055
# Local dev overrides with the LAN ingresses below — backend config only, NEVER
# user-facing links (CLAUDE.md hard rule 3).
SONARR_URL=https://sonarr.haynesops.com
RADARR_URL=https://radarr.haynesops.com
LIDARR_URL=https://lidarr.haynesops.com
SEERR_URL=https://seerr.haynesops.com
# Bazarr is the subtitle manager the missing_subtitles Fix routes to (ADR-016 / DESIGN-005
# D-19). Not an *arr — its own URL default is http://bazarr.media.svc.cluster.local:6767.
BAZARR_URL=https://bazarr.haynesops.com

# API keys are secrets: cluster = ExternalSecret from 1Password `HaynesKube` vault
# (media-stack / lidarr items — DESIGN-005 D-18 table); local dev = copy the same
# fields into .env.local. The SONARR/RADARR/LIDARR/SEERR four are required by assertArrEnv;
# BAZARR_API_KEY is additionally required (assertBazarrEnv) for the subtitle Fix (ADR-016).
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
SEERR_API_KEY=
BAZARR_API_KEY=

# --- Ledger sync runner (@hnet/sync) — DESIGN-005 D-14 ------------------------------
# No extra variables: the CronJob CLI consumes DATABASE_URL plus the *arr/Seerr
# URL/API_KEY pairs above (only the keys for the sources a run targets are required,
# so `--source=radarr` needs just RADARR_*). Invocations (in-cluster CronJobs:
# sync-incremental every 15 min; sync-full at 04:30 = cron `30 4 * * *`, backoffLimit 1;
# locally via `pnpm --filter @hnet/sync sync`):
#   tsx /sync/src/scripts/sync.ts --mode=incremental
#   tsx /sync/src/scripts/sync.ts --mode=full [--source=…] [--force-tombstones]

# --- Library metadata enrichment (@hnet/sync --mode=metadata-refresh) — ADR-018 / DESIGN-008 --
# ALL of the following are OPTIONAL and skip-if-absent: the app + harvest boot cleanly with none
# set (local-dev default), and each tier degrades independently. Cluster = ExternalSecret from
# 1Password (`HaynesKube` vault / homepage item) added to `haynesnetwork-secret`. In-cluster
# CronJob `sync-metadata`: `tsx /sync/src/scripts/sync.ts --mode=metadata-refresh`, schedule
# `15 */6 * * *`, concurrencyPolicy Forbid.
#
# Tautulli watch-stats — THREE estate instances (URLs default to in-cluster service DNS except
# haynestower, the external legacy box, which needs an explicit URL):
# TAUTULLI_API_KEY=                     # HaynesOps (tautulli.media.svc.cluster.local:8181)
# TAUTULLI_K8PLEX_API_KEY=              # HaynesKube (tautulli-k8plex.media.svc.cluster.local:8181)
# TAUTULLI_HAYNESTOWER_API_KEY=         # HaynesTower (external — set TAUTULLI_HAYNESTOWER_URL too)
# TAUTULLI_HAYNESTOWER_URL=
#
# Direct TMDB / TVDB fallback for metadata holes (tombstoned / never-listed rows). Prefer the
# TMDB v4 read-access bearer; the v3 key also works. RT has no public API (stays *arr-only).
# TMDB_API_READ_ACCESS_TOKEN=
# TMDB_API_KEY=
# TVDB_API_KEY=
#
# Maintainerr computed rule-collection props (best-effort). Opt-in: set the URL and/or key.
# MAINTAINERR_URL=                      # default http://maintainerr.media.svc.cluster.local:6246
# MAINTAINERR_API_KEY=

# --- Bulletin webhook receivers (ADR-026 / DESIGN-012 — PLAN-009) ---------------------
# The POST /api/webhooks/<source> receiver is session-unauthenticated but PER-SOURCE
# shared-secret-gated. Each secret is REQUIRED to enable its source (fail-closed: an unset
# secret 503s that source's endpoint). The source services POST the IN-CLUSTER URL and carry
# the secret via x-webhook-secret / Authorization / ?token= (see DESIGN-012 D-03 deploy notes).
# Generate distinct high-entropy values; never commit real values (External Secrets + 1Password
# in-cluster). MAINTAINERR_WEBHOOK_SECRET is reused from PLAN-006.
# MAINTAINERR_WEBHOOK_SECRET=
# SEERR_WEBHOOK_SECRET=
# TAUTULLI_WEBHOOK_SECRET=

# --- Plex library self-service (@hnet/plex) — ADR-017 / DESIGN-007 D-03 env contract -
# One URL + owner TOKEN per server, keyed by the canonical OWNER SLUGS (haynestower /
# haynesops / hayneskube — NOT the ingress subdomains plexops/k8plex). URLs are non-secret
# config with per-server defaults (DESIGN-007 D-12): haynesops / hayneskube default to their
# in-cluster PMS service DNS; haynestower is the EXTERNAL Unraid box (no in-cluster Service) so
# it defaults to its public ingress instead:
#   haynestower → https://plex.haynesnetwork.com        (external — reachable from cluster pods)
#   haynesops   → http://plexops.media.svc.cluster.local:32400
#   hayneskube  → http://plex.media.svc.cluster.local:32400
# Local dev overrides with the LAN ingresses below (backend config only — NEVER user-facing).
PLEX_HAYNESTOWER_URL=https://plex.haynesnetwork.com
PLEX_HAYNESOPS_URL=https://plexops.haynesnetwork.com
PLEX_HAYNESKUBE_URL=https://k8plex.haynesnetwork.com
# The three OWNER tokens are secrets (X-Plex-Token, account-owner scope for the sharing API):
# cluster = ExternalSecret from 1Password `HaynesKube` vault, `homepage` item fields
# HAYNESTOWER_PLEX_API_KEY / HAYNESOPS_PLEX_API_KEY / HAYNESKUBE_PLEX_API_KEY (DESIGN-007 D-11);
# local dev = copy the same fields into .env.local. Required by assertPlexEnv; never echoed.
PLEX_HAYNESTOWER_TOKEN=
PLEX_HAYNESOPS_TOKEN=
PLEX_HAYNESKUBE_TOKEN=
# The plex.tv sharing API host. Defaults to https://plex.tv; overridden only by the e2e stub.
# PLEX_TV_URL=

# --- Authentik role portal (@hnet/authentik) — ADR-045 / DESIGN-023 D-17 env contract -----
# haynesnetwork writes Authentik GROUP MEMBERSHIP when an admin assigns a Role (the cross-app role
# primitive; see /admin/users). AUTHENTIK_URL is non-secret config with an in-cluster default; reaching
# Authentik in-cluster BYPASSES the Cloudflare edge that bans Python's default UA (error 1010, OPS-001).
# Default (in-cluster Service DNS, namespace `network`):
#   http://authentik-server.network.svc.cluster.local
AUTHENTIK_URL=
# The API TOKEN is a secret and required (assertAuthentikEnv) — the dedicated `hnet-portal` SERVICE
# ACCOUNT token, NEVER the shared homepage admin token. Cluster = the CLUSTER-CREATED secret
# `haynesnetwork-authentik-token` (a 1Password migration is a follow-up nicety); local dev = copy the
# token into .env.local. Header-only (Authorization: Bearer) — never echoed. The as-executed RBAC scope
# is recorded in OPS-011.
AUTHENTIK_API_TOKEN=

# Open WebUI GROUP client (@hnet/openwebui) — REUSES the PLAN-021 usage-sync env (no new secret): the
# portal pre-creates the same-named OWUI group for a synced tier (OWUI doesn't auto-create from claims).
# OPENWEBUI_URL is non-secret with an in-cluster default (http://open-webui.ai.svc.cluster.local);
# OPENWEBUI_API_KEY is the secret (cluster = ExternalSecret from 1Password `openwebui` item; also the
# ai-usage-sync key, ADR-044 C-06). Both already consumed by PLAN-021 — listed here for completeness.
# OPENWEBUI_URL=
# OPENWEBUI_API_KEY=

# ADR-046 / DESIGN-024 (PLAN-023) — the BOOKS read clients (@hnet/books, read-only). The books-sync mode
# AND the /api/books/cover proxy authenticate to Kavita + Audiobookshelf with these. URLs + usernames are
# non-secret with in-cluster + bootstrap-account defaults; the PASSWORDS are the secrets (cluster =
# ExternalSecret from the 1Password `kavita`/`audiobookshelf` items → app secret; local dev = .env.local).
# The PUBLIC URLs seed the stored deep links (opens in a new tab). Absent passwords ⇒ books-sync/cover no-op.
# KAVITA_URL=                       # default http://kavita.media.svc.cluster.local:5000
# KAVITA_USERNAME=                  # default hnetadmin
# KAVITA_PASSWORD=
# KAVITA_PUBLIC_URL=                # default https://kavita.haynesnetwork.com
# AUDIOBOOKSHELF_URL=               # default http://audiobookshelf.media.svc.cluster.local:13378
# AUDIOBOOKSHELF_USERNAME=          # default root
# AUDIOBOOKSHELF_PASSWORD=
# AUDIOBOOKSHELF_PUBLIC_URL=        # default https://audiobookshelf.haynesnetwork.com
